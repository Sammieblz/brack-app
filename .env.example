# Brack environment template
# Copy this file to `.env` for local Vite development.
# Keep real values out of git. Values prefixed with `VITE_` are exposed to the browser.

# -----------------------------------------------------------------------------
# Frontend runtime - required by src/integrations/supabase/client.ts
# -----------------------------------------------------------------------------

# Your Supabase project URL.
# Example: https://your-project-ref.supabase.co
VITE_SUPABASE_URL=

# Your Supabase publishable/anon key.
# This is safe to expose to the browser when Row Level Security is configured.
VITE_SUPABASE_PUBLISHABLE_KEY=

# Optional. Not currently required by the app runtime, but useful for tooling or
# scripts that need the project ref.
# Example: your-project-ref
VITE_SUPABASE_PROJECT_ID=

# Optional. Used by Supabase CLI commands when applying migrations or deploying
# functions from automation. Do not expose this to frontend code.
SUPABASE_ACCESS_TOKEN=

# Optional. Required by Supabase CLI database commands such as
# `npx supabase db push --linked`. This is the direct Postgres database
# password from the Supabase dashboard, not an app user password.
SUPABASE_DB_PASSWORD=

# Optional. Enables Sentry browser error reporting when set.
# Leave blank to disable Sentry locally.
VITE_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Supabase Edge Functions / backend secrets
# -----------------------------------------------------------------------------
# These are NOT browser variables. Do not prefix them with `VITE_`.
# For deployed functions, set them with Supabase secrets.
# For local function serving, pass them through the Supabase CLI env file.

# Supabase project URL for Edge Functions.
SUPABASE_URL=

# Supabase anon key for Edge Functions that intentionally run as the caller.
SUPABASE_ANON_KEY=

# Supabase service-role key for trusted Edge Functions and server-only work.
# Never expose this in frontend code or any `VITE_` variable.
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Used by the `search-books` Edge Function.
# The function can call Google Books without this, but quota and reliability are
# better with an API key.
GOOGLE_BOOKS_API_KEY=

# Optional. Required only for push notifications through
# `send-push-notification`.
FCM_SERVER_KEY=

# Comma-separated list of allowed browser origins for Edge Function CORS.
# Include local dev and any deployed app origins.
# Example: http://localhost:8080,http://127.0.0.1:8080,https://brack.app
ALLOWED_ORIGINS=

# Edge Function environment mode. Use `development` locally.
# This affects CORS behavior in shared function helpers.
ENVIRONMENT=development
