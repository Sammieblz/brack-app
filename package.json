    "eslint-plugin-react-refresh": "^0.4.9",
    "globals": "^15.9.0",
    "lovable-tagger": "^1.1.7",
    "postcss": "^8.4.47",
    "sharp": "^0.32.6",
    "supabase": "^2.95.6",
    "tailwindcss": "^3.4.11",
    "turbo": "^2.9.18",
    "typescript": "^5.5.3",
    "typescript-eslint": "^8.0.1",
    "vite": "^5.4.1",
    "vite-plugin-pwa": "^1.1.0",
    "wait-on": "^9.0.5"
  }
}
