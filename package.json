{
  "name": "brack-monorepo",
  "private": true,
  "version": "0.0.0",
  "description": "Brack reading tracker app for web, mobile, and desktop.",
  "author": {
    "name": "Brack",
    "email": "support@brack.app",
    "url": "https://brack.app"
  },
  "homepage": "https://brack.app",
  "license": "UNLICENSED",
  "main": "apps/desktop/dist/main.cjs",
  "type": "module",
  "packageManager": "npm@11.3.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=@brack/client",
    "build": "turbo run build --filter=@brack/client",
    "build:dev": "turbo run build:dev --filter=@brack/client",
    "check-types": "turbo run check-types",
    "lint": "turbo run lint",
    "preview": "turbo run preview --filter=@brack/client",
    "brand:icons": "node scripts/generate-brand-icons.mjs",
    "desktop:typecheck": "turbo run check-types --filter=@brack/desktop",
    "desktop:build": "turbo run build --filter=@brack/desktop",
    "desktop:rebuild": "electron-rebuild -f -w better-sqlite3",
    "desktop:dev": "turbo run //#_desktop:dev",
    "desktop:pack": "turbo run //#_desktop:pack",
    "desktop:dist": "turbo run //#_desktop:dist",
    "desktop:dist:win": "turbo run //#_desktop:dist:win",
    "desktop:dist:mac": "turbo run //#_desktop:dist:mac",
    "desktop:dist:mac:arm64": "turbo run //#_desktop:dist:mac:arm64",
    "desktop:dist:mac:x64": "turbo run //#_desktop:dist:mac:x64",
    "desktop:dist:linux": "turbo run //#_desktop:dist:linux",
    "cap:sync": "turbo run sync --filter=@brack/mobile",
    "cap:sync:android": "turbo run sync:android --filter=@brack/mobile",
    "cap:sync:ios": "turbo run sync:ios --filter=@brack/mobile",
    "cap:open:ios": "turbo run open:ios --filter=@brack/mobile",
    "cap:open:android": "turbo run open:android --filter=@brack/mobile",
    "_desktop:dev": "npm --workspace @brack/desktop run build && npm run desktop:rebuild && concurrently -k -s first -n client,electron \"npm --workspace @brack/client run dev\" \"wait-on http://127.0.0.1:8080 && cross-env BRACK_ELECTRON_DEV_SERVER_URL=http://127.0.0.1:8080 electron .\"",
    "_desktop:pack": "electron-builder --dir --publish=never",
    "_desktop:dist": "electron-builder --publish=never",
    "_desktop:dist:win": "electron-builder --win --x64 --publish=never",
    "_desktop:dist:mac": "electron-builder --mac --publish=never",
    "_desktop:dist:mac:arm64": "electron-builder --mac --arm64 --publish=never",
    "_desktop:dist:mac:x64": "electron-builder --mac --x64 --publish=never",
    "_desktop:dist:linux": "electron-builder --linux --x64 --publish=never"
  },
  "dependencies": {
    "@capacitor-community/sqlite": "^7.0.3",
    "@capacitor/android": "^7.4.4",
    "@capacitor/app": "^7.1.0",
    "@capacitor/browser": "^7.0.5",
    "@capacitor/camera": "^7.0.3",
    "@capacitor/cli": "^7.4.4",
    "@capacitor/core": "^7.4.4",
    "@capacitor/device": "^7.0.2",
    "@capacitor/filesystem": "^7.1.6",
    "@capacitor/haptics": "^7.0.2",
    "@capacitor/ios": "^7.4.4",
    "@capacitor/local-notifications": "^7.0.4",
    "@capacitor/network": "^7.0.2",
    "@capacitor/push-notifications": "^7.0.4",
    "@capacitor/share": "^7.0.3",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@gsap/react": "^2.1.2",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-alert-dialog": "^1.1.1",
    "@radix-ui/react-aspect-ratio": "^1.1.0",
    "@radix-ui/react-avatar": "^1.1.0",
    "@radix-ui/react-checkbox": "^1.1.1",
    "@radix-ui/react-collapsible": "^1.1.0",
    "@radix-ui/react-context-menu": "^2.2.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.1",
    "@radix-ui/react-hover-card": "^1.1.1",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-menubar": "^1.1.1",
    "@radix-ui/react-navigation-menu": "^1.2.0",
    "@radix-ui/react-popover": "^1.1.1",
    "@radix-ui/react-progress": "^1.1.0",
    "@radix-ui/react-radio-group": "^1.2.0",
    "@radix-ui/react-scroll-area": "^1.1.0",
    "@radix-ui/react-select": "^2.1.1",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slider": "^1.2.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-switch": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.0",
    "@radix-ui/react-toast": "^1.2.1",
    "@radix-ui/react-toggle": "^1.1.0",
    "@radix-ui/react-toggle-group": "^1.1.0",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@sentry/browser": "^10.32.1",
    "@sentry/react": "^10.32.1",
    "@supabase/supabase-js": "^2.53.0",
    "@tanstack/query-sync-storage-persister": "^5.90.13",
    "@tanstack/react-query": "^5.56.2",
    "@tanstack/react-query-persist-client": "^5.90.13",
    "@tanstack/react-virtual": "^3.13.12",
    "@tiptap/extension-character-count": "^3.26.1",
    "@tiptap/extension-link": "^3.26.1",
    "@tiptap/extension-mention": "^3.26.1",
    "@tiptap/extension-placeholder": "^3.26.1",
    "@tiptap/extension-underline": "^3.26.1",
    "@tiptap/react": "^3.26.1",
    "@tiptap/starter-kit": "^3.26.1",
    "@types/dompurify": "^3.0.5",
    "@zxing/library": "^0.21.3",
    "apexcharts": "^5.10.6",
    "better-sqlite3": "^12.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.0.0",
    "date-fns": "^3.6.0",
    "dexie": "^4.4.2",
    "dompurify": "^3.3.1",
    "embla-carousel-react": "^8.3.0",
    "emoji-picker-react": "^4.19.1",
    "framer-motion": "^12.33.0",
    "gsap": "^3.14.2",
    "iconoir-react": "^7.11.0",
    "input-otp": "^1.2.4",
    "lottie-react": "^2.4.1",
    "next-themes": "^0.3.0",
    "react": "^18.3.1",
    "react-apexcharts": "^2.1.0",
    "react-day-picker": "^8.10.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.0",
    "react-resizable-panels": "^2.1.3",
    "react-router-dom": "^6.26.2",
    "react-simple-pull-to-refresh": "^1.3.3",
    "react-swipeable": "^7.0.2",
    "sonner": "^1.5.0",
    "tailwind-merge": "^2.5.2",
    "tailwindcss-animate": "^1.0.7",
    "tesseract.js": "^7.0.0",
    "vaul": "^0.9.3",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@electron/rebuild": "^4.0.4",
    "@eslint/js": "^9.9.0",
    "@tailwindcss/typography": "^0.5.15",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.5.5",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react-swc": "^3.5.0",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^41.5.0",
    "electron-builder": "^26.8.1",
